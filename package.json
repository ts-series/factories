{
	"name": "@ts-series/factories",
	"version": "1.1.0",
	"description": "A lightweight TypeScript DSL for generating HTML, SVG and MathML server-side without a template engine.",
	"type": "module",
	"author": "Enrico Rippin",
	"license": "Unlicense",
	"engines": {
		"node": ">=18"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./svg": {
			"types": "./dist/svg.d.ts",
			"default": "./dist/svg.js"
		},
		"./mathml": {
			"types": "./dist/mathml.d.ts",
			"default": "./dist/mathml.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/ts-series/factories.git"
	},
	"files": [
		"dist",
		"README.md"
	],
	"keywords": [
		"domain-specific",
		"dsl",
		"html",
		"language",
		"mathml",
		"svg",
		"template"
	]
}