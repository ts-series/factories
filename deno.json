{
	"name": "@ts-series/factories",
	"version": "1.1.0",
	"author": "Enrico Rippin <e@rippin.org>",
	"description": "A lightweight TypeScript DSL for generating HTML, SVG and MathML server-side without a template engine.",
	"exports": {
		".": "./src/index.ts",
		"./svg": "./src/svg.ts",
		"./mathml": "./src/mathml.ts"
	},
	"compilerOptions": {
		"strict": true,
		"checkJs": true
	},
	"unstable": ["sloppy-imports"],
	"lint": {
		"rules": {
			"exclude": ["no-sloppy-imports"]
		}
	},
	"license": "Unlicense",
	"repository": {
		"type": "git",
		"url": "https://github.com/ts-series/factories.git"
	}
}